{
  "mcpServers": {
    "snowflake": {
      "command": "python",
      "args": ["-m", "snowflake_mcp_server"],
      "env": {
        "SNOWFLAKE_ACCOUNT": "${SNOWFLAKE_ACCOUNT}",
        "SNOWFLAKE_USER": "${SNOWFLAKE_USER}",
        "SNOWFLAKE_PASSWORD": "${SNOWFLAKE_PASSWORD}",
        "SNOWFLAKE_ROLE": "${SNOWFLAKE_ROLE}",
        "SNOWFLAKE_WAREHOUSE": "${SNOWFLAKE_WAREHOUSE}"
      }
    },
    "snowflake_account_b": {
      "command": "python",
      "args": ["-m", "snowflake_mcp_server"],
      "env": {
        "SNOWFLAKE_ACCOUNT": "${SNOWFLAKE_ACCOUNT_B}",
        "SNOWFLAKE_USER": "${SNOWFLAKE_USER_B}",
        "SNOWFLAKE_PASSWORD": "${SNOWFLAKE_PASSWORD_B}",
        "SNOWFLAKE_ROLE": "${SNOWFLAKE_ROLE_B}",
        "SNOWFLAKE_WAREHOUSE": "${SNOWFLAKE_WAREHOUSE_B}"
      }
    },
    "azure_devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp"],
      "env": {
        "AZDO_PAT": "${AZDO_PAT}",
        "AZDO_ORG_URL": "${AZDO_ORG_URL}"
      }
    }
  }
}
